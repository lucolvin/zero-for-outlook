{
  "name": "Zero for Outlook",
  "description": "Zero for Outlook adds configurable keyboard shortcuts and extends functionality of Outlook on the web.",
  "version": "0.8.0",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://outlook.cloud.microsoft/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.zero-extension.com/*",
    "https://*.zero-extension.com/*",
    "http://localhost:8787/*",
    "http://localhost:4173/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*",
        "https://outlook.cloud.microsoft/*"
      ],
      "js": [
        "contentScript.vite.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}

