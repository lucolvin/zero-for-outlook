{
  "name": "zero-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "docker:up": "docker compose -f ../docker-compose.yml up --build",
    "api:dev": "tsx watch server/index.ts",
    "api:build": "esbuild server/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=api-dist/index.mjs --packages=external",
    "api:serve": "node api-dist/index.mjs",
    "api:start": "tsx server/index.ts"
  },
  "dependencies": {
    "@clerk/backend": "^1.24.3",
    "@clerk/clerk-react": "^5.22.11",
    "@tanstack/react-query": "^5.62.9",
    "@tanstack/react-router": "^1.89.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase": "^11.7.1",
    "firebase-admin": "^13.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
