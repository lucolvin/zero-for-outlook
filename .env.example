# =============================================================================
# Monorepo — copy to `.env` in the repo root (site, API, Docker, extension build)
# =============================================================================

# Client-side (safe to expose in browser bundle)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
VITE_AUTH_SITE_URL=http://localhost:4173
VITE_API_BASE_URL=http://localhost:8787
VITE_FIREBASE_API_KEY=replace-me
VITE_FIREBASE_AUTH_DOMAIN=replace-me.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=replace-me
VITE_FIREBASE_STORAGE_BUCKET=replace-me.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-me
VITE_FIREBASE_APP_ID=replace-me

# Server-side only (never expose to browser; used by Firebase Admin SDK)
CLERK_SECRET_KEY=sk_test_replace_me
API_PORT=8787

FIREBASE_PROJECT_ID=replace-me
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----\n"

# =============================================================================
# Browser extension — not loaded from any .env file. Paste into Options →
# Account → Developer override (or use as reference when wiring the extension).
# =============================================================================
# ZERO_AUTH_SITE_URL=http://localhost:4173
# ZERO_API_BASE_URL=http://localhost:8787
